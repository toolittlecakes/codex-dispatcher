{
  "name": "codex-dispatcher",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "codex-dispatcher": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "doctor": "bun run src/cli.ts doctor",
    "build:binary": "bun build --compile --target=bun --outfile=dist/codex-dispatcher src/cli.ts",
    "dev": "bun run src/server.ts",
    "dev:tunnel": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "typescript": "^5.9.3"
  }
}
